# Omega Quiz — environment defaults
# -----------------------------------------------------------------------------
# Copy this file to `.env` (same directory as server.js) and uncomment the
# lines you want to override. The server reads `.env` at startup; values
# already set in the real process environment ALWAYS win, so this file is
# for defaults, not enforcement.
#
# `.env` should NOT be committed — add it to .gitignore (.env.example may be).
# -----------------------------------------------------------------------------


# =============================================================================
# Server
# =============================================================================

# TCP port to bind. Most hosting platforms (Railway, Fly, Render) set this
# automatically — leave commented in those environments.
# PORT=3000

# Set to 'production' to enable HTTPS redirect, HSTS, and the requirement that
# HOST_TOKEN and ADMIN_TOKEN below are explicitly set.
# NODE_ENV=production

# Where data/config.json (branding) and data/questions.json (question bank)
# are persisted. Point at a mounted volume for persistence across restarts.
# DATA_DIR=./data

# HMAC key for session cookies. REQUIRED in production. Random-per-boot if
# unset (dev only) — every restart invalidates active sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# COOKIE_SECRET=replace-me-with-32-bytes-of-randomness

# Recovery tokens. Required in production. In dev they auto-generate per
# boot and get printed on the boot banner. Don't commit real values.
# HOST_TOKEN=
# ADMIN_TOKEN=

# Trust X-Forwarded-For (controls per-IP rate limits + audit logs):
#   auto (default) — trust XFF when the socket peer looks like a reverse
#                    proxy (loopback / RFC1918 / 100.64-CGN / known Cloudflare
#                    edge). Right for Railway, Render, Fly, Docker, nginx.
#   1 / true       — always trust XFF (use behind any proxy chain).
#   0 / false      — never trust XFF; rate-limit by socket peer only.
#                    Use for direct public exposure with no proxy at all.
# A wrong setting collapses every per-IP rate-limit bucket to one entry
# (defeating brute-force / join-code throttling), so pick deliberately.
# TRUST_PROXY=auto


# =============================================================================
# Public URLs / connectivity
# =============================================================================

# Drives QR-code links, magic-link URLs, and the join URL on the host screen.
# Defaults to the request's Host header when unset. The admin Branding tab
# can override this at runtime without restarting.
# PUBLIC_BASE_URL=https://quiz.example.com

# Override the manifest the admin "Browse sample packs" modal pulls from.
# Defaults to the bundled samples/manifest.json shipped with the project.
# SAMPLE_PACKS_URL=https://raw.githubusercontent.com/you/your-repo/main/samples/manifest.json

# Bootstrap the question bank on first run. Only fires when the on-disk bank
# is empty — does NOT overwrite existing data/questions.json. JSON or CSV.
# Same as the `-u` / `--seed-url` CLI flag (which wins if both are set).
# QUESTIONS_SEED_URL=https://raw.githubusercontent.com/you/your-repo/main/pack.json


# =============================================================================
# Branding (admin → Branding tab defaults)
#
# These are applied ONLY on first run — once the admin saves anything in the
# Branding tab, data/config.json is written and these env vars stop being
# consulted. To re-apply env defaults, delete data/config.json and restart.
# =============================================================================

# Company / organisation name. Shown as a prefix on the host screen and in
# the player join screen. Leave empty for the generic title.
# COMPANY_NAME=Acme Corp

# Domain used in the "use your @<domain>" hint on the player join screen.
# Just the domain, no leading @.
# COMPANY_DOMAIN=acme.com

# When true, players must use a matching @<COMPANY_DOMAIN> email to join.
# Accepted: 1, true, yes, on (case-insensitive). Defaults to false.
# RESTRICT_DOMAIN=false

# Sub-title under the main quiz title on the host screen.
# TAGLINE=Quarterly cybersecurity refresher

# Display title (player + host pages). Defaults to "Omega Quiz".
# QUIZ_TITLE=Omega Quiz

# Informational tag — usually set automatically when a sample pack is loaded.
# QUIZ_CATEGORY=cyber

# Privacy notice shown above the Join button on the player screen. Aim for a
# short sentence covering: who collects (you), what is collected (name + email),
# how long it's kept (in-memory until session end), and what it's used for.
# Set to an empty string to suppress the notice entirely (operator's risk).
# Limited HTML allowlist: <em>, <br>, <span class="mono">.
# CONSENT_TEXT=By joining you agree to share your name and work email with the session facilitator. Data is held in memory only and cleared when the session ends.


# =============================================================================
# Game behaviour (admin → Branding tab toggles)
# =============================================================================

# Prize ladder style on the host projector. 'money' shows $100 → $1M (WWTBAM
# style); 'levels' shows "Level 1" → "Level N" (neutral / training-friendly).
# LEVEL_STYLE=money

# Show real player names + run the award ceremony at end-of-game. Set to
# false for anonymous training mode (results table only, no names).
# SHOW_NAMES_AT_END=true

# How players commit answers. 'quick' = tap-to-commit (one tap, one answer);
# 'confirm' = tap to highlight, then tap "Lock In Answer".
# ANSWER_LOCK_MODE=quick

# When true, eliminated players can still tap an answer each question (no
# scoring, just engagement) — they see their running correct count at the end.
# ELIMINATED_CAN_ANSWER=false

# When the three lifelines (50/50, Ask IT, Skip) refill:
#   never           — one of each per game (classic WWTBAM)
#   each-question   — fresh set every question (training mode)
#   at-bonus        — fresh set when the bonus / tiebreaker round starts
# LIFELINE_REFILL=never

# Session-closed CTA — shown on the "session ended" screen new visitors see
# after an admin clicks "Close session" in the admin Settings tab. Leave both
# blank to hide the button. URL must start with https://, http://, or mailto:.
# CLOSED_SESSION_CTA_LABEL=Take the follow-up survey
# CLOSED_SESSION_CTA_URL=https://survey.example.com/post-session


# =============================================================================
# Theme — CSS custom-property colours (hex)
#
# Same nine variables that the admin Theme editor exposes. Values must be
# 6-digit hex (e.g. #f4c430). Anything else falls back to the built-in
# default for that key.
# =============================================================================

# THEME_NAVY_DEEP=#020625
# THEME_NAVY_MID=#050d3d
# THEME_NAVY_LIGHT=#0a1660
# THEME_GOLD=#f4c430
# THEME_GOLD_BRIGHT=#ffd700
# THEME_GOLD_DIM=#8a6d10
# THEME_RED=#c41e3a
# THEME_GREEN=#1ea14a
# THEME_WHITE=#f5f3e8


# =============================================================================
# Logging
# =============================================================================

# Set to '1' to suppress the structured JSON log line emitter (operational
# events, auth, rate-limit, crash). Tests set NODE_ENV=test which also
# disables it. Off by default in production — Fly/Render/Railway parse the
# JSON automatically and index its fields.
# LOG_DISABLE_JSON=0
